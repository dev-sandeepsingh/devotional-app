{
  "title": "அனுமன் சாலிசா",
  "intro": "இறைவன் அனுமனுக்கு அர்ப்பணிக்கப்பட்ட பக்திப் பாடல்.",
  "meaning": "இந்த சாலிசா அனுமனின் வலிமை, பக்தி மற்றும் சேவையைப் புகழ்கிறது.",
  "faq": {
    "q1": "அனுமன் சாலிசா எப்போது சொல்ல வேண்டும்?",
    "a1": "பாரம்பரியமாக செவ்வாய் மற்றும் சனிக்கிழமைகளில்.",
    "q2": "இதை எந்த மொழியிலும் சொல்ல முடியுமா?",
    "a2": "ஆம், பக்தி மொழியை விட முக்கியமானது."
  }
}
