# Copy to .env and adjust for your environment.

# Backend API base URL — consumed app-wide via src/admin/api.js (apiFetch),
# which every page's data fetching goes through. Includes the /api/v1 base path.
# Local: http://localhost:4000/api/v1   Prod: https://your-api-host/api/v1
VITE_API_URL=http://localhost:4000/api/v1

# Backend host used by the Vite dev proxy (vite.config.js). Keep the host in
# sync with VITE_API_URL above.
VITE_API_PROXY_TARGET=http://localhost:4000
