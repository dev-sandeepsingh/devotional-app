# Copy to .env and adjust for your environment.

# Backend API base URL — consumed app-wide via src/admin/api.js (apiFetch),
# which every page's data fetching goes through. Includes the /api/v1 base path.
#
# Local dev (below): http://localhost:4000/api/v1
# Production: set this in the host's env vars (e.g. Vercel → Settings → Environment
# Variables), NOT in a committed file. VITE_* vars are inlined at BUILD time, so a
# redeploy is required after changing it. Current prod backend:
#   https://devotional-app-api-production.up.railway.app/api/v1
VITE_API_URL=https://devotional-app-api-production.up.railway.app/api/v1

# Backend host used by the Vite dev proxy (vite.config.js). Keep the host in
# sync with VITE_API_URL above.
VITE_API_PROXY_TARGET=https://devotional-app-api-production.up.railway.app
